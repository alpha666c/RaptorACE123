{
  "name": "personal-coding-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Private, production-grade personal coding agent (VS Code extension + web oversight).",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' run build && pnpm -C apps/extension run build",
    "build:packages": "pnpm -r --filter='./packages/*' run build",
    "build:extension": "pnpm -C apps/extension run build",
    "test": "pnpm -r --filter='./packages/*' run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --filter='./packages/*' exec tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}
