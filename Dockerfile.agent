# syntax=docker/dockerfile:1.7
#
# Docker image for the standalone agent runtime (apps/agent-runtime).
# Packages the full coding agent as a long-running process behind the
# @agent/server HTTP surface, driven by the web UI (Dockerfile.web).
#
# Usage on Coolify:
#   - Point Coolify at this repo and set the Dockerfile path to Dockerfile.agent.
#   - Mount a persistent volume at /workspace for the target repo (you clone
#     into it on first deploy, or via an init container).
#   - Set env vars: OPENROUTER_API_KEY, AGENT_SERVER_TOKEN (otherwise auto-
#     generated on each start — you want persistence), and any MCP secrets
#     declared in mcp.config.json's envKeys (CONTEXT7_API_KEY, etc.).

FROM node:24-slim AS build

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@11.0.8 --activate

WORKDIR /build

# Root workspace manifests first to leverage Docker layer cache.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json ./

# Copy every package.json so pnpm can resolve the workspace graph without
# pulling in src yet (better cache hits on src-only edits).
COPY apps/extension/package.json ./apps/extension/
COPY apps/web/package.json ./apps/web/
COPY apps/agent-runtime/package.json ./apps/agent-runtime/
COPY packages/shared/package.json ./packages/shared/
COPY packages/permissions/package.json ./packages/permissions/
COPY packages/tools/package.json ./packages/tools/
COPY packages/memory/package.json ./packages/memory/
COPY packages/model-gateway/package.json ./packages/model-gateway/
COPY packages/mcp/package.json ./packages/mcp/
COPY packages/skills/package.json ./packages/skills/
COPY packages/server/package.json ./packages/server/
COPY packages/core/package.json ./packages/core/

RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

# Now the real sources.
COPY packages ./packages
COPY apps/agent-runtime ./apps/agent-runtime

# Build every workspace package the runtime depends on, then the runtime itself.
RUN pnpm -r --filter='./packages/*' run build
RUN pnpm -C apps/agent-runtime run build


FROM node:24-slim AS runtime

# git + openssh-client so the agent can operate against a real repo mounted at /workspace.
RUN apt-get update && apt-get install -y --no-install-recommends git openssh-client ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@11.0.8 --activate

WORKDIR /app

# Copy the whole monorepo — we need workspace symlinks at runtime for sql.js
# and for the MCP servers spawned via npx.
COPY --from=build /build /app

# Non-root user for the agent (can't touch /root, writes into /workspace).
RUN useradd -m -u 1001 agent && chown -R agent:agent /app
USER agent

ENV AGENT_SERVER_HOST=0.0.0.0
ENV AGENT_SERVER_PORT=23456
ENV AGENT_WORKSPACE=/workspace

VOLUME ["/workspace"]
EXPOSE 23456

CMD ["node", "apps/agent-runtime/dist/main.js"]
